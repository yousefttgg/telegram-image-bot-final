FROM python:3.11-slim

LABEL version="5.0.0-embedded"

WORKDIR /app

RUN mkdir -p /data

RUN pip install --no-cache-dir aiogram==3.13.1 aiohttp==3.10.10

RUN python -c "import sqlite3; print('sqlite3:', sqlite3.sqlite_version)"

RUN echo "" | base64 -d > /app/main.py

RUN python -c "
src = open('/app/main.py').read()
assert 'psycopg2' not in src
assert 'asyncpg' not in src  
assert 'sqlite3' in src
assert 'aiohttp' in src
print('✅ main.py OK - lines:', src.count(chr(10)))
"

EXPOSE 8080
CMD ["python", "/app/main.py"]
